<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ title }} | ArtHouse</title>
    <link rel="stylesheet" href="/styles/site.css">
  </head>
  <body>
    <div class="dvd-background" aria-hidden="true" data-dvd-layer>
      <img class="dvd-video-mark" src="/assets/arthouse.svg" alt="" data-dvd-bouncer>
    </div>

    <div class="page-shell">
      <header class="site-header">
        <button class="third-eye-toggle" type="button" aria-label="open third eye" data-third-eye-state="closed" data-third-eye-toggle>
          <img src="/assets/eye_closed.svg" alt="" data-third-eye-icon>
        </button>

        <nav class="site-nav" aria-label="Primary">
          <a href="/">Home</a>
          {% if currentArtist %}
            {% if isAdmin %}
              <a href="/admin">Admin</a>
            {% else %}
              <a href="/dashboard">Dashboard</a>
            {% endif %}
            <form class="inline-form" action="/logout" method="post">
              <button class="link-button" type="submit">Logout</button>
            </form>
          {% else %}
            <a href="/register">Register</a>
            <a href="/login">Login</a>
          {% endif %}
        </nav>
      </header>

      <main class="site-main">
        {% block content %}{% endblock %}
      </main>

    </div>
    <script src="/scripts/dvd-background.js"></script>
    <script src="/scripts/third-eye-toggle.js"></script>
    {% block scripts %}{% endblock %}
  </body>
</html>
