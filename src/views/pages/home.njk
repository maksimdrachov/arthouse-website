{% extends "layouts/base.njk" %}

{% block content %}
  <section class="window home-transparent-window">
    <div class="window-body">
      {% if items.length %}
        <div class="public-item-grid public-item-grid-home" data-home-item-grid>
          {% for item in items %}
            <a class="public-item-card" href="/products/{{ item.id }}" data-home-item-id="{{ item.id }}">
              <span class="public-item-photo">
                {% if item.primaryPhoto %}
                  <img src="{{ item.primaryPhoto.path }}" alt="">
                {% else %}
                  <span>No photo</span>
                {% endif %}
              </span>
              <span class="public-item-name">{{ item.name }}</span>
              {% if item.artist %}
                <span class="public-item-artist">{{ item.artist.name }}</span>
              {% endif %}
              <span class="public-item-price">{{ item.priceDisplay }}</span>
            </a>
          {% endfor %}
        </div>
        {% if hasMoreItems %}
          <div class="home-load-more-actions">
            <button class="home-load-more-button" type="button" data-home-load-more data-home-load-more-url="/api/home-items">load more</button>
          </div>
        {% endif %}
      {% else %}
        <p>No items are available yet. Seed demo data with <code>npm run seed:demo</code>.</p>
      {% endif %}
    </div>
  </section>

  <section class="window home-transparent-window">
    <div class="window-body">
      <h2 class="home-section-title">Artists</h2>

      {% if artists.length %}
        <div class="artist-banner-list">
          {% for artist in artists %}
            <a class="artist-banner-link" href="/artists/{{ artist.slug }}">
              {% if artist.bannerPath %}
                <img src="{{ artist.bannerPath }}" alt="">
              {% endif %}
              <span>{{ artist.name }}</span>
            </a>
          {% endfor %}
        </div>
      {% else %}
        <p>No artist stores are available yet.</p>
      {% endif %}
    </div>
  </section>
{% endblock %}

{% block scripts %}
  <script src="/scripts/home-load-more.js"></script>
{% endblock %}
