{% extends "layouts/base.njk" %}

{% block content %}
  <section class="window">
    <div class="window-body">
      <div class="section-heading">
        <h1>{{ artist.name }}</h1>
        <div class="item-actions">
          {% if adminBackPath %}
            <a href="{{ adminBackPath }}">Back to admin</a>
          {% endif %}
          <a class="button-link" href="{{ profileEditPath }}">Edit profile</a>
        </div>
      </div>

      {% if registered %}
        <div class="message message-info">Account created. You are logged in.</div>
      {% endif %}
      {% if profileUpdated %}
        <div class="message message-info">Profile updated.</div>
      {% endif %}
      {% if itemCreated %}
        <div class="message message-info">Item added.</div>
      {% endif %}
      {% if itemUpdated %}
        <div class="message message-info">Item updated.</div>
      {% endif %}
      {% if itemDeleted %}
        <div class="message message-info">Item removed.</div>
      {% endif %}
      {% if reservationUpdated %}
        <div class="message message-info">Reservation updated.</div>
      {% endif %}

      {% if artist.bannerPath %}
        <img class="profile-banner" src="{{ artist.bannerPath }}" alt="">
      {% endif %}

      <dl class="detail-list">
        <div>
          <dt>Bank account</dt>
          <dd>{{ artist.bankAccount }}</dd>
        </div>
        {% if artist.telegram %}
          <div>
            <dt>Telegram channel</dt>
            <dd>{{ artist.telegram }}</dd>
          </div>
        {% endif %}
        {% if artist.instagram %}
          <div>
            <dt>Instagram</dt>
            <dd>{{ artist.instagram }}</dd>
          </div>
        {% endif %}
        {% if artist.about %}
          <div>
            <dt>About</dt>
            <dd>{{ artist.about }}</dd>
          </div>
        {% endif %}
      </dl>
    </div>
  </section>

  {% if showReservations %}
    <section class="window">
      <div class="window-body">
        <h2>Reservations</h2>

        {% if reservations.length %}
          <div class="table-scroll">
            <table class="data-table">
              <thead>
                <tr>
                  <th>Item</th>
                  <th>Reserved</th>
                  <th>Telegram</th>
                  <th>Status</th>
                  <th>Action</th>
                </tr>
              </thead>
              <tbody>
                {% for reservation in reservations %}
                  <tr>
                    <td>
                      {% if reservation.item %}
                        <a href="/products/{{ reservation.item.id }}">{{ reservation.item.name }}</a>
                      {% else %}
                        Removed item #{{ reservation.itemId }}
                      {% endif %}
                    </td>
                    <td>{{ reservation.reservedAt }}</td>
                    <td>{{ reservation.customerTelegram }}</td>
                    <td>{{ reservation.status }}</td>
                    <td>
                      {% if reservation.status == "pending" %}
                        <form class="inline-form" action="/dashboard/reservations/{{ reservation.id }}/status" method="post">
                          <input type="hidden" name="status" value="paid">
                          <button class="link-button" type="submit">Paid</button>
                        </form>
                        <form class="inline-form" action="/dashboard/reservations/{{ reservation.id }}/status" method="post" onsubmit="return confirm('Cancel this reservation?');">
                          <input type="hidden" name="status" value="cancelled">
                          <button class="link-button danger-link" type="submit">Cancel</button>
                        </form>
                      {% endif %}
                    </td>
                  </tr>
                {% endfor %}
              </tbody>
            </table>
          </div>
        {% else %}
          <p>No reservations have been placed for your items yet.</p>
        {% endif %}
      </div>
    </section>
  {% endif %}

  <section class="window">
    <div class="window-body">
      <div class="section-heading">
        <h2>Store items</h2>
        <a class="button-link" href="{{ itemActionBasePath }}/new">Add item</a>
      </div>

      {% if items.length %}
        <div class="item-admin-grid">
          {% for item in items %}
            <article class="item-admin-card">
              <div class="item-admin-photo">
                {% if item.primaryPhoto %}
                  <img src="{{ item.primaryPhoto.path }}" alt="">
                {% else %}
                  <span>No photo</span>
                {% endif %}
              </div>

              <div class="item-admin-body">
                <h3>{{ item.name }}</h3>
                <p>{{ item.priceDisplay }}</p>

                <form class="compact-form" action="{{ itemActionBasePath }}/{{ item.id }}/availability" method="post">
                  <label>
                    <span>Availability</span>
                    <select name="availability">
                      <option value="available" {% if item.availability == "available" %}selected{% endif %}>Available</option>
                      <option value="reserved" {% if item.availability == "reserved" %}selected{% endif %}>Reserved</option>
                      <option value="sold" {% if item.availability == "sold" %}selected{% endif %}>Sold</option>
                    </select>
                  </label>
                  <button type="submit">Update</button>
                </form>

                <div class="item-actions">
                  <a href="{{ itemActionBasePath }}/{{ item.id }}/edit">Edit</a>
                  <form class="inline-form" action="{{ itemActionBasePath }}/{{ item.id }}/delete" method="post" onsubmit="return confirm('Remove this item?');">
                    <button class="link-button danger-link" type="submit">Remove</button>
                  </form>
                </div>
              </div>
            </article>
          {% endfor %}
        </div>
      {% else %}
        <p>No items yet.</p>
      {% endif %}
    </div>
  </section>
{% endblock %}
