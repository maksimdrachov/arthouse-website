{% extends "layouts/base.njk" %}

{% block content %}
  <section class="window">
    <div class="window-title">Edit profile</div>
    <div class="window-body">
      <h1>Edit profile</h1>

      {% if errors.length %}
        <div class="message message-error" role="alert">
          <ul>
            {% for error in errors %}
              <li>{{ error }}</li>
            {% endfor %}
          </ul>
        </div>
      {% endif %}

      {% if artist.bannerPath %}
        <img class="profile-banner" src="{{ artist.bannerPath }}" alt="">
      {% endif %}

      <form class="form-grid" action="/dashboard/profile" method="post" enctype="multipart/form-data">
        <label class="form-row">
          <span>Artist name</span>
          <input name="name" value="{{ values.name }}" autocomplete="name" required>
        </label>

        <label class="form-row">
          <span>New password</span>
          <input name="password" type="password" autocomplete="new-password" minlength="8">
        </label>

        <label class="form-row">
          <span>Bank account</span>
          <input name="bankAccount" value="{{ values.bankAccount }}" autocomplete="off" required>
        </label>

        <label class="form-row">
          <span>About</span>
          <textarea name="about" rows="4">{{ values.about }}</textarea>
        </label>

        <label class="form-row">
          <span>Telegram</span>
          <input name="telegram" value="{{ values.telegram }}" autocomplete="off">
        </label>

        <label class="form-row">
          <span>Instagram</span>
          <input name="instagram" value="{{ values.instagram }}" autocomplete="off">
        </label>

        <label class="form-row">
          <span>Store banner</span>
          <input name="banner" type="file" accept="image/jpeg,image/png,image/gif,image/webp">
        </label>

        <div class="form-actions">
          <button type="submit">Save profile</button>
          <a href="/dashboard">Cancel</a>
        </div>
      </form>
    </div>
  </section>
{% endblock %}
